{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://explain-project/narrative.schema.json",
  "title": "narrative.json",
  "description": "Claude's grounded interpretation layer over facts.json. Validated by verify.py against the facts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "basedOnFactsCommit", "tiers", "nodes", "relationships", "openQuestions"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "basedOnFactsCommit": { "type": ["string", "null"] },
    "tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["level", "name"],
        "properties": {
          "level": { "type": "integer", "minimum": 0 },
          "name": { "type": "string" }
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "tier", "label", "description", "factRefs", "children", "confidence", "interpretation"],
        "properties": {
          "id": { "type": "string" },
          "tier": { "type": "integer", "minimum": 0 },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "factRefs": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "moduleIds": { "type": "array", "items": { "type": "string" } },
              "fileIds": { "type": "array", "items": { "type": "string" } }
            }
          },
          "children": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "interpretation": { "type": "boolean" }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "label", "factEdgeIds", "confidence"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "label": { "type": "string" },
          "factEdgeIds": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      }
    },
    "openQuestions": { "type": "array", "items": { "type": "string" } }
  }
}
