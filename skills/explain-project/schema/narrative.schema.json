{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://explain-project/narrative.schema.json",
  "title": "narrative.json",
  "description": "Claude's grounded interpretation layer over facts.json. Validated by verify.py against the facts. v2 carries multiple switchable perspectives; the v1 single-narrative shape remains accepted.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "basedOnFactsCommit", "openQuestions"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "basedOnFactsCommit": { "type": ["string", "null"] },
    "tiers": { "$ref": "#/$defs/tiers" },
    "nodes": { "$ref": "#/$defs/nodes" },
    "relationships": { "$ref": "#/$defs/relationships" },
    "perspectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "kind", "description", "tiers", "nodes", "relationships"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "kind": { "type": "string", "enum": ["structural", "functional", "dataflow", "runtime", "domain"] },
          "description": { "type": "string" },
          "tiers": { "$ref": "#/$defs/tiers" },
          "nodes": { "$ref": "#/$defs/nodes" },
          "relationships": { "$ref": "#/$defs/relationships" }
        }
      }
    },
    "businessBrief": { "$ref": "#/$defs/businessBrief" },
    "openQuestions": { "type": "array", "items": { "type": "string" } }
  },
  "oneOf": [
    { "required": ["perspectives"] },
    { "required": ["tiers", "nodes", "relationships"] }
  ],
  "$defs": {
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "briefFactRefs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "moduleIds": { "type": "array", "items": { "type": "string" } },
        "fileIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "briefClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "factRefs", "confidence", "interpretation"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "factRefs": { "$ref": "#/$defs/briefFactRefs" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "interpretation": { "type": "boolean" }
      }
    },
    "businessBrief": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "problem", "solution"],
      "properties": {
        "headline": { "type": "string", "minLength": 1 },
        "problem": { "$ref": "#/$defs/briefClaim" },
        "solution": { "$ref": "#/$defs/briefClaim" },
        "audience": { "$ref": "#/$defs/briefClaim" },
        "howItWorks": { "type": "string" },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "text", "factRefs", "confidence", "interpretation"],
            "properties": {
              "label": { "type": "string", "minLength": 1 },
              "text": { "type": "string", "minLength": 1 },
              "factRefs": { "$ref": "#/$defs/briefFactRefs" },
              "confidence": { "$ref": "#/$defs/confidence" },
              "interpretation": { "type": "boolean" },
              "perspectiveRef": { "type": "string" },
              "nodeRef": { "type": "string" }
            }
          }
        },
        "techStack": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "role", "factRef"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "role": { "type": "string" },
              "factRef": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["level", "name"],
        "properties": {
          "level": { "type": "integer", "minimum": 0 },
          "name": { "type": "string" }
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "tier", "label", "description", "factRefs", "children", "confidence", "interpretation"],
        "properties": {
          "id": { "type": "string" },
          "tier": { "type": "integer", "minimum": 0 },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "factRefs": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "moduleIds": { "type": "array", "items": { "type": "string" } },
              "fileIds": { "type": "array", "items": { "type": "string" } }
            }
          },
          "children": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "interpretation": { "type": "boolean" }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "label", "factEdgeIds", "confidence"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "label": { "type": "string" },
          "factEdgeIds": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      }
    }
  }
}
